rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailAdmin() {
      return isSignedIn() && request.auth.token.email == 'talingpangu5@gmail.com';
    }
    function isAdmin() { 
      return isEmailAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // Subscriptions
    match /subscriptions/{subId} {
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isEmailAdmin() || (isOwner(resource.data.userId));
      allow update, delete: if isAdmin();
    }

    // Settings
    match /settings/mining {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Wallets
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin(); // Only system/admin can update wallet balances
    }
    
    // Admin list
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }
  }
}
